# Copy this file to .env and adjust values for your local machine.

# Credentials used by FastAPI and avatar/server.js protected APIs.
API_KEY=
API_SECRET=
API_SIGNATURE_TOLERANCE_SECONDS=300
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*
API_CAPTURE_CAMERA_INDEX=0
API_CAPTURE_WARMUP_FRAMES=8
API_UPLOAD_DIR=

# Set to 1 only if you want the legacy Node avatar server to pre-generate
# every text/name/voice variant at startup.
ENABLE_TTS_PREWARM=0

# Set to 1 only for demo/testing runs where startup should clear attendance
# records and Redis check-in state.
CLEAR_TEST_DATA=0

# MySQL stores attendance records.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=attendance
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_SIZE=5

# PostgreSQL + pgvector stores face embeddings.
PG_HOST=127.0.0.1
PG_PORT=5434
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=face_db
PG_POOL_SIZE=5

# Redis stores check-in de-duplication state and event messages.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Face detection/tracking quality gates.
CAMERA_BUFFER_SIZE=1
INSIGHTFACE_DET_SIZE=640x640
MAX_PROCESS_FACES=3
OPENCV_TRACKER_TYPE=KCF
MATCH_ACCEPT_THRESHOLD=0.62
MATCH_REVIEW_THRESHOLD=0.52
MATCH_PERSON_TOP_K=3
VOTE_WINDOW=5
FACE_MIN_MATCH_SIZE=96
FACE_MIN_DET_SCORE=0.65
FACE_EDGE_MARGIN=24
FACE_MIN_EYE_DISTANCE=28
FACE_MAX_POSE_IMBALANCE=0.45
UNKNOWN_CACHE_TTL_SECONDS=1.0
UNKNOWN_CACHE_EMBEDDING_DELTA=0.08
UNKNOWN_VISITOR_MATCH_THRESHOLD=0.58
UNKNOWN_VISITOR_UPDATE_COOLDOWN_SECONDS=300
UNKNOWN_ENROLL_MIN_HITS=5
UNKNOWN_ENROLL_MAX_EMPLOYEE_SIMILARITY=0.45
UNKNOWN_ENROLL_MIN_FACE_SIZE=140
UNKNOWN_ENROLL_MIN_DET_SCORE=0.78
UNKNOWN_ENROLL_MAX_POSE_IMBALANCE=0.30

# Edge TTS voice used by the Python voice queue.
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_VOICE_EPSILON=zh-CN-XiaoyiNeural
TTS_VOICE_CHITOSE=zh-TW-YunJheNeural
TTS_VOICE_HARU_GREETER=zh-CN-XiaoxiaoNeural
TTS_VOICE_HARU=zh-CN-XiaoyiNeural
TTS_VOICE_NATORI=zh-TW-YunJheNeural

# Doubao realtime voice dialog. Optional; keep disabled until keys are configured.
# If dependencies are missing, install with:
# pip install -r requirements.txt -i https://pypi.tuna.tsinghua.edu.cn/simple
ENABLE_REALTIME_DIALOG=1
REALTIME_DIALOG_APP_ID=
REALTIME_DIALOG_ACCESS_KEY=
REALTIME_DIALOG_BASE_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue
REALTIME_DIALOG_RESOURCE_ID=volc.speech.dialog
REALTIME_DIALOG_SPEAKER=zh_female_xiaohe_jupiter_bigtts
REALTIME_DIALOG_OUTPUT_FORMAT=pcm_s16le
REALTIME_DIALOG_BOT_NAME=前台小助手
REALTIME_DIALOG_SYSTEM_ROLE=你是公司前台数字人，性格开朗、亲切、有一点害羞。你正在接待来访者和同事。
REALTIME_DIALOG_SPEAKING_STYLE=回复要简短自然，每次一到两句话，像真人前台一样温柔活泼，不要长篇解释。
REALTIME_DIALOG_CITY=北京
REALTIME_DIALOG_RECV_TIMEOUT=10
REALTIME_DIALOG_SAY_HELLO=0
REALTIME_DIALOG_RELEASE_GRACE_SECONDS=0.8
REALTIME_DIALOG_INPUT_SAMPLE_RATE=16000
REALTIME_DIALOG_INPUT_CHUNK=3200
REALTIME_DIALOG_OUTPUT_SAMPLE_RATE=24000
REALTIME_DIALOG_OUTPUT_CHUNK=3200

# Daily avatar quote generation. Keep API key empty to use built-in fallback texts.
DAILY_QUOTES_MODEL=qwen3.6-flash-2026-04-16
DAILY_QUOTES_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DAILY_QUOTES_API_KEY=
DAILY_QUOTES_TIMEOUT_SECONDS=60
DAILY_QUOTES_TEMPERATURE=0.9
